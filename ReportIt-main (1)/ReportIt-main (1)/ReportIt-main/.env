# Use Vite dev proxy (recommended — same as Postman targets, no CORS issues)
VITE_USE_PROXY=true

# Leave empty when VITE_USE_PROXY=true (requests go to localhost:5173/api/... then proxy)
VITE_AUTH_URL=
VITE_API_URL=

# Direct mode (like Postman): set VITE_USE_PROXY=false and uncomment:
# VITE_USE_PROXY=false
# VITE_AUTH_URL=http://localhost:8081
# VITE_API_URL=http://localhost:8082
