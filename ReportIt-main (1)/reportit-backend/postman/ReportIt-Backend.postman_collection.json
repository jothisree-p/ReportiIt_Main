{
  "info": {
    "name": "ReportIt Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "authUrl", "value": "http://localhost:8081" },
    { "key": "apiUrl", "value": "http://localhost:8082" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Register Citizen",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{authUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jothisree\",\n  \"email\": \"jothisree@example.com\",\n  \"phone\": \"9876543210\",\n  \"password\": \"pass123\"\n}"
            }
          }
        },
        {
          "name": "Login Citizen",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json.accessToken) pm.collectionVariables.set('token', json.accessToken);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{authUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jothisree@example.com\",\n  \"password\": \"pass123\",\n  \"role\": \"CITIZEN\"\n}"
            }
          }
        },
        {
          "name": "Login Admin",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json.accessToken) pm.collectionVariables.set('token', json.accessToken);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{authUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@reportit.com\",\n  \"password\": \"admin123\",\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{authUrl}}/api/auth/otp/send",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jothisree@example.com\",\n  \"purpose\": \"FORGOT_PASSWORD\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{authUrl}}/api/auth/otp/verify",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jothisree@example.com\",\n  \"otp\": \"123456\",\n  \"purpose\": \"FORGOT_PASSWORD\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Complaints",
      "item": [
        {
          "name": "Create Complaint",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{apiUrl}}/api/complaints",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Bike Theft\",\n  \"category\": \"Theft\",\n  \"description\": \"Stolen near market\",\n  \"locationText\": \"Market Area\",\n  \"priority\": \"High\"\n}"
            }
          }
        },
        {
          "name": "Get All Complaints",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{apiUrl}}/api/complaints"
          }
        },
        {
          "name": "Get My Complaints",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{apiUrl}}/api/complaints/citizen/me"
          }
        },
        {
          "name": "Update Complaint",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{apiUrl}}/api/complaints/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"In Progress\",\n  \"priority\": \"High\",\n  \"note\": \"Investigation started\"\n}"
            }
          }
        },
        {
          "name": "Delete Complaint",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{apiUrl}}/api/complaints/1"
          }
        }
      ]
    },
    {
      "name": "Officers",
      "item": [
        {
          "name": "Create Officer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{apiUrl}}/api/officers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ravi Prakash\",\n  \"email\": \"ravi.prakash@reportit.com\",\n  \"password\": \"ravi123\",\n  \"badge\": \"RP-4521\",\n  \"position\": \"Inspector\",\n  \"zone\": \"Zone A\",\n  \"initials\": \"RP\",\n  \"status\": \"Active\"\n}"
            }
          }
        },
        {
          "name": "Get All Officers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{apiUrl}}/api/officers"
          }
        }
      ]
    },
    {
      "name": "Admin Users",
      "item": [
        {
          "name": "Get All Citizens",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{apiUrl}}/api/admin/users"
          }
        }
      ]
    },
    {
      "name": "Profiles",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{apiUrl}}/api/profiles/me"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Admin Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{apiUrl}}/api/dashboard/admin/stats"
          }
        }
      ]
    },
    {
      "name": "Status Tracking",
      "item": [
        {
          "name": "Track by Code",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{apiUrl}}/api/status/track/CMP-2026-001"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get My Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{apiUrl}}/api/notifications/me"
          }
        }
      ]
    },
    {
      "name": "Roles",
      "item": [
        {
          "name": "Get All Roles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{apiUrl}}/api/roles"
          }
        }
      ]
    }
  ]
}
